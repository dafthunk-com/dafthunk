{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "dafthunk-app",
  "compatibility_date": "2025-11-17",

  // Static assets configuration with native SPA fallback
  "assets": {
    "binding": "ASSETS",
    "directory": "./dist",
    "not_found_handling": "single-page-application"
  }
}
